# ── Base de datos SQLite ─────────────────────────────────────────────────────
# En Railway: apunta al volumen persistente montado en /app/prisma/
DATABASE_URL="file:/app/prisma/prod.db"

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Generá una clave larga y aleatoria. Ejemplo: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-una-clave-secreta-larga"

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Servicio SMTP: gmail | outlook | hotmail | yahoo
SMTP_SERVICE="gmail"

# Cuenta desde la que se envían los emails
SMTP_USER="tu-cuenta@gmail.com"

# Para Gmail: App Password de 16 chars (no tu contraseña normal)
# Generala en: https://myaccount.google.com/apppasswords
SMTP_PASS="xxxx xxxx xxxx xxxx"

# Nombre que aparece como remitente
EMAIL_FROM_NAME="CNRT - Sistema de Inventario"

# Email inicial del admin (los siguientes se agregan desde el panel)
# Puede ser vacío si los configurás desde la interfaz después del deploy
ADMIN_EMAIL="admin@cnrt.gob.ar"
